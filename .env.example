# Database
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# WordPress Admin
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com

# Site
WP_SITE_TITLE="WP Test"

# Seeding (opt-out for non-WooCommerce plugin developers)
# When true (default), init.sh installs WooCommerce and seeds sample data.
# Set to false to get a plain WordPress install — measurably faster.
SEED_WOOCOMMERCE=true

# Plugin Bind-Mounts (optional — for live plugin development)
# Comma-separated absolute or repo-relative directories. Each entry is
# mounted into /var/www/html/wp-content/plugins/<basename> on every WP
# service, so edits reflect instantly without a rebuild.
#   Example: PLUGIN_PATHS=./my-plugin,/Users/me/another-plugin
# Leave empty to disable (default).
PLUGIN_PATHS=
